# ─── Database ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/courses_db

# ─── JWT Auth ────────────────────────────────────────
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_MINUTES=120
REFRESH_TOKEN_MINUTES=10080

# ─── Redis ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── App URLs ────────────────────────────────────────
# Frontend URL used in email links (e.g. Vercel URL in production)
FRONTEND_URL=http://localhost:5173
# Backend URL (used for CORS, Render URL in production)
BACKEND_URL=http://localhost:8000

# ─── Email Verification ──────────────────────────────
REQUIRE_EMAIL_VERIFICATION=true

# ─── SMTP Configuration ──────────────────────────────
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587         (STARTTLS) or 465 (SSL)
#   SMTP_USERNAME=your-email@gmail.com
#   SMTP_PASSWORD=xxxx xxxx xxxx xxxx  (Gmail App Password - NOT your account password)
#   SMTP_FROM_EMAIL=your-email@gmail.com
#   SMTP_FROM_NAME=StudentCoursera

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=StudentCoursera
